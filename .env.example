# AgentDock Builder — Environment Variables

# ── Required ──────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-32-char-string-here
ADMIN_EMAIL=admin@agentdock.local
ADMIN_PASSWORD=changeme

# ── Ports ─────────────────────────────────────────────────────────────────────
BUILDER_UI_PORT=3000
BUILDER_API_PORT=3001

# ── Storage ───────────────────────────────────────────────────────────────────
# Where the builder stores its SQLite database and generated zips
# (auto-created if missing)
DATABASE_PATH=./data/builder.db
OUTPUT_DIR=./data/generated
