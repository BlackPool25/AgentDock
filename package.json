{
  "name": "agentdock",
  "version": "0.2.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "docker compose -f docker/builder.docker-compose.yml up --build",
    "build": "bun run --filter '*' build",
    "typecheck": "bun run --filter '*' typecheck",
    "db:push": "cd apps/builder-api && bun run db:push"
  },
  "devDependencies": {
    "bun-types": "^1.3.14"
  }
}
